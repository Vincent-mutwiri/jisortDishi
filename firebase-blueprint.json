{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "dietary_preferences": { "type": "array", "items": { "type": "string" } },
        "budget_preference": { "type": "number" },
        "currency": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "email", "created_at"]
    },
    "Storage": {
      "title": "Storage",
      "description": "A storage unit like a fridge or pantry",
      "type": "object",
      "properties": {
        "storage_id": { "type": "string" },
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["fridge", "pantry", "store"] },
        "name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["storage_id", "user_id", "type", "created_at"]
    },
    "Item": {
      "title": "Item",
      "description": "An item stored in a storage unit",
      "type": "object",
      "properties": {
        "item_id": { "type": "string" },
        "storage_id": { "type": "string" },
        "user_id": { "type": "string" },
        "item_name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "expiry_date": { "type": "string", "format": "date-time" },
        "date_added": { "type": "string", "format": "date-time" }
      },
      "required": ["item_id", "storage_id", "user_id", "item_name", "quantity", "unit", "date_added"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A cooking recipe",
      "type": "object",
      "properties": {
        "recipe_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "amount": { "type": "string" }
            }
          } 
        },
        "steps": { "type": "array", "items": { "type": "string" } },
        "estimated_cost": { "type": "number" },
        "preparation_time": { "type": "number" },
        "created_by": { "type": "string" },
        "price": { "type": "number" },
        "is_public": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["recipe_id", "title", "ingredients", "steps", "estimated_cost", "preparation_time", "created_by", "created_at"]
    },
    "MealSuggestion": {
      "title": "MealSuggestion",
      "description": "A generated meal suggestion based on budget and ingredients",
      "type": "object",
      "properties": {
        "suggestion_id": { "type": "string" },
        "user_id": { "type": "string" },
        "recipe_id": { "type": "string" },
        "budget_used": { "type": "number" },
        "based_on_items": { "type": "array", "items": { "type": "string" } },
        "generated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["suggestion_id", "user_id", "recipe_id", "generated_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/storage/{storageId}": {
      "schema": "Storage",
      "description": "Storage units for a user"
    },
    "/users/{userId}/storage/{storageId}/items/{itemId}": {
      "schema": "Item",
      "description": "Items in a specific storage unit"
    },
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Global recipe library"
    },
    "/users/{userId}/suggestions/{suggestionId}": {
      "schema": "MealSuggestion",
      "description": "Meal suggestions history for a user"
    }
  }
}
